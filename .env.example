PORT=3980

# --- MySQL — bật registry qua DB khi đặt MYSQL_HOST / MYSQL_DATABASE / hoặc PLATFORM_REGISTRY=mysql ---
# Schema + bảng platform_bots tự tạo; database được CREATE IF NOT EXISTS nếu user có quyền.
# PLATFORM_REGISTRY=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=basso_platform
# MYSQL_CONNECTION_LIMIT=15

# Token đọc repo GitHub private khi clone bot (quyền repo đọc là đủ)
# GITHUB_CLONE_TOKEN=ghp_xxx

# --- Đăng nhập /admin (một trong hai cách) ---
# Cách A — Basso partner (ưu tiên khi đủ BASSO_URL + BASSO_API_KEY):
BASSO_URL=https://basso.vn
BASSO_API_KEY=dSQcZoUsi1DprkC8zkB8xEZd2JoxCtqBwwp5ig
# Các biến trùng tên với server/.env.example của bot (vd. BASSO_*, ANTHROPIC_API_KEY) được gán mặc định
# khi tạo bot / wizard .env — chỉ những key Platform không có mới cần điền thủ công.
# Cách B — Tài khoản cố định trên platform (khi không dùng Basso):
PLATFORM_ADMIN_USER=itbee@gmail.com
PLATFORM_ADMIN_PASSWORD=123123

# Bắt buộc khi dùng Basso cho admin: ký session (không dùng mật khẩu local làm secret)
# PLATFORM_SESSION_SECRET=

# Log chi tiết đăng nhập /admin + chat-login (HTTP Basso, không log mật khẩu). Tắt trên production nếu muốn.
# PLATFORM_AUTH_DEBUG=1

# Tuỳ chọn: bật thì tab «Quản lý bot» trên dashboard yêu cầu nhập thêm mật khẩu này (sau khi đã đăng nhập admin).
# PLATFORM_MANAGE_TAB_PASSWORD=
# PLATFORM_PYTHON_TAB_PASSWORD=

# --- Redis (docker-compose) — bot PM2 kế thừa REDIS_* từ process Platform; kết nối host `redis`, port 6379
# Tuỳ chọn đổi khi chạy Redis ngoài compose:
# REDIS_HOST=redis
# REDIS_PORT=6379
# Mật khẩu: cấu hình thêm trên image Redis (không có sẵn trong compose mặc định). Xem docs/REDIS-BOT-SESSION.md

# Port nội bộ đầu tiên cho từng bot (4100, 4101, …)
BOT_PORT_START=4100

# Tab admin «Logs hệ thống»: docker logs container Platform (cần docker trên PATH + quyền daemon)
# Tên container mặc định = hostname trong container; compose thường là tên kiểu folder-platform-1
PLATFORM_DOCKER_LOGS_CONTAINER=platform-ai-platform-1
# Khi không gọi được Docker: đọc tail file (đường dẫn tuyệt đối hoặc tương đối cwd)
# PLATFORM_SYSTEM_LOG_PATH=/var/log/platform.log

# Watchdog: gọi GET http://127.0.0.1:{port}/health mỗi bot đang running; lỗi liên tiếp → pm2 restart
# Tắt: PLATFORM_BOT_HEALTH_WATCHDOG=0
# PLATFORM_BOT_HEALTH_INTERVAL_MS=45000
# PLATFORM_BOT_HEALTH_TIMEOUT_MS=5000
# PLATFORM_BOT_HEALTH_PATH=/health
# PLATFORM_BOT_HEALTH_FAILURES=2
# PLATFORM_BOT_HEALTH_COOLDOWN_MS=120000

# --- Bộ nhớ bot (gợi ý VPS 4 core / 8 GB RAM) ---
# Quy tắc thô: OS+Nginx+MySQL ~1.5–2G + platform ~0.5G + (số_bot × mỗi_bot) < 8G.
# Ví dụ 8–10 bot: heap ~384M + PM2 cap ~450M/bot → còn dự phòng cho spike.
BOT_NODE_OPTIONS=--max-old-space-size=384
# PM2 restart process bot nếu RSS vượt ngưỡng (khớp hoặc hơn heap một chút)
BOT_PM2_MAX_MEMORY=450M

# Một domain production — link chat trong dashboard: https://ai.basso.vn/b/{id}/
PUBLIC_ORIGIN=https://ai.basso.vn

# https://ai.basso.vn/ → redirect admin (đặt 0 để tắt)
# PLATFORM_ROOT_REDIRECT=/admin/dashboard.html

# Bot dùng làm backend đăng nhập Basso chung (mặc định: bot running đầu tiên trong registry)
# PLATFORM_PROXY_AUTH_BOT_ID=a1b2c3d4e5f67890

# --- Sinh cấu hình Nginx (npm run gen:nginx) ---
NGINX_DOMAIN=ai.basso.vn
# NGINX_PLATFORM_PORT=3980
# Đường dẫn mặc định khi dùng Let’s Encrypt — xem platform/docs/SSL-LETSENCRYPT.md
# NGINX_SSL_CERT=/etc/letsencrypt/live/ai.basso.vn/fullchain.pem
# NGINX_SSL_KEY=/etc/letsencrypt/live/ai.basso.vn/privkey.pem
